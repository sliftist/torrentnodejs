{
    "compilerOptions": {
        "strict": true,
        "module": "CommonJS",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "node",
        "target": "ES2020",
        "jsx": "react",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "alwaysStrict": true,
        "types": [
            "node"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": false,
        "skipLibCheck": true,
        "inlineSourceMap": true,
        "inlineSources": true
    },
    "exclude": [
        "node_modules"
    ]
}
